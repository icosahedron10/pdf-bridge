# Copy to .env. Do not commit the populated file. Generate every secret independently, for example:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
PDF_BRIDGE_SESSION_SECRET=CHANGE_ME_generate_a_long_random_session_secret
PDF_BRIDGE_QDRANT_API_KEY=CHANGE_ME_generate_a_long_random_qdrant_admin_key
PDF_BRIDGE_EMBEDDING_API_TOKEN=CHANGE_ME_private_embedding_service_token
PDF_BRIDGE_LLM_API_TOKEN=CHANGE_ME_private_llm_service_token

# POC defaults. `enterprise` refuses anonymous-poc at startup.
PDF_BRIDGE_APP_ENV=development
PDF_BRIDGE_AUTH_MODE=anonymous-poc
PDF_BRIDGE_BIND_ADDRESS=127.0.0.1
PDF_BRIDGE_PORT=8000

# Compose fixes storage and Qdrant URLs to private service names. Direct processes need absolute,
# non-synchronized storage and an authenticated Qdrant URL.
# PDF_BRIDGE_STORAGE_ROOT=/var/lib/pdf-bridge
# PDF_BRIDGE_DATABASE_URL=sqlite+pysqlite:////var/lib/pdf-bridge/catalog.sqlite3
# PDF_BRIDGE_QDRANT_URL=http://127.0.0.1:6333

# JSON arrays are required for list-valued Pydantic settings.
PDF_BRIDGE_ALLOWED_HOSTS=["localhost","127.0.0.1"]
PDF_BRIDGE_TRUSTED_PROXY_CIDRS=[]
PDF_BRIDGE_TRUSTED_IDENTITY_HEADER=X-Forwarded-User

PDF_BRIDGE_BRAND_PRIMARY_1="#173f34"
PDF_BRIDGE_BRAND_PRIMARY_2="#0f3028"
PDF_BRIDGE_BRAND_SECONDARY_1="#d5a846"
PDF_BRIDGE_BRAND_SECONDARY_2="#d9c78f"
PDF_BRIDGE_THEME_DEFAULT=system

PDF_BRIDGE_COLLECTIONS=[{"key":"customer","display_name":"Customer Product","description":"Approved product and support material available to customer-facing assistants.","audience":"customer"},{"key":"internal","display_name":"HR & Internal","description":"Employee-only policy and operations material.","audience":"internal"}]

PDF_BRIDGE_MAX_UPLOAD_BYTES=52428800
PDF_BRIDGE_MAX_UPLOAD_FILES=20
PDF_BRIDGE_UPLOAD_CHUNK_BYTES=1048576
PDF_BRIDGE_CLAMD_TIMEOUT=30
PDF_BRIDGE_CLAMD_STREAM_MAX_BYTES=67108864

# Exactly one application process owns this two-slot worker.
PDF_BRIDGE_WORKER_ENABLED=true
PDF_BRIDGE_WORKER_POLL_SECONDS=1
PDF_BRIDGE_WORKER_LEASE_SECONDS=300
PDF_BRIDGE_WORKER_HEARTBEAT_SECONDS=30
PDF_BRIDGE_PARSE_WALL_CLOCK_SECONDS=120
PDF_BRIDGE_PARSE_CPU_SECONDS=90
PDF_BRIDGE_PARSE_MEMORY_BYTES=1073741824
PDF_BRIDGE_ANALYSIS_MAX_PAGES=2000
PDF_BRIDGE_ANALYSIS_MAX_CHARACTERS=5000000
PDF_BRIDGE_ANALYSIS_MAX_CHUNKS=10000

# Private OpenAI-compatible endpoints. Model IDs and dimensions are deployment-pinned.
PDF_BRIDGE_EMBEDDING_API_URL=https://models.internal.example/v1
PDF_BRIDGE_EMBEDDING_MODEL_ID=CHANGE_ME_embedding_model_id
PDF_BRIDGE_EMBEDDING_DIMENSION=CHANGE_ME_embedding_dimension
PDF_BRIDGE_EMBEDDING_TIMEOUT=30
PDF_BRIDGE_LLM_API_URL=https://models.internal.example/v1
PDF_BRIDGE_LLM_CLASSIFIER_MODEL=CHANGE_ME_classifier_model_id
PDF_BRIDGE_LLM_VERIFIER_MODEL=CHANGE_ME_verifier_model_id
PDF_BRIDGE_LLM_TIMEOUT=60
PDF_BRIDGE_QDRANT_TIMEOUT=30

# Leave blank only when the operator-facing Library search proxy is intentionally unavailable.
PDF_BRIDGE_SEARCH_API_URL=
PDF_BRIDGE_SEARCH_API_TOKEN=
PDF_BRIDGE_SEARCH_API_TIMEOUT=10
