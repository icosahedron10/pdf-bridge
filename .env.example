# Copy to .env. Do not commit the populated file.
# Generate each secret independently, for example:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
PDF_BRIDGE_SESSION_SECRET=CHANGE_ME_generate_a_long_random_session_secret
PDF_BRIDGE_JOB_TOKEN=CHANGE_ME_generate_a_different_long_random_job_token

# POC defaults. `enterprise` refuses anonymous-poc at startup.
PDF_BRIDGE_APP_ENV=development
PDF_BRIDGE_AUTH_MODE=anonymous-poc
PDF_BRIDGE_BIND_ADDRESS=127.0.0.1
PDF_BRIDGE_PORT=8000

# Compose fixes this to its named volume. For a direct process, set an absolute path outside the
# checkout and OneDrive, for example PDF_BRIDGE_STORAGE_ROOT=C:/Users/me/AppData/Local/pdf-bridge.
# PDF_BRIDGE_STORAGE_ROOT=
# PDF_BRIDGE_DATABASE_URL=

# JSON arrays are required for list-valued Pydantic settings.
PDF_BRIDGE_ALLOWED_HOSTS=["localhost","127.0.0.1"]
PDF_BRIDGE_TRUSTED_PROXY_CIDRS=[]
PDF_BRIDGE_TRUSTED_IDENTITY_HEADER=X-Forwarded-User

PDF_BRIDGE_MAX_UPLOAD_BYTES=52428800
PDF_BRIDGE_MAX_UPLOAD_FILES=20
PDF_BRIDGE_CLAMD_TIMEOUT=30
PDF_BRIDGE_CLAMD_STREAM_MAX_BYTES=67108864
PDF_BRIDGE_CLAIM_LEASE_MINUTES=30

# Leave blank only when Library search is intentionally unavailable.
PDF_BRIDGE_SEARCH_API_URL=
PDF_BRIDGE_SEARCH_API_TOKEN=
