# PDF Bridge API v2. Copy to .env and replace every CHANGE_ME independently.
# Generate random secrets (except the scoped Qdrant JWT) with:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
PDF_BRIDGE_SESSION_SECRET=CHANGE_ME_generate_a_long_random_session_secret
# Compose-launcher only: Qdrant's HS256 signing/admin key. Never pass this to Bridge.
PDF_BRIDGE_QDRANT_ADMIN_API_KEY=CHANGE_ME_qdrant_admin_signing_key
# Pre-generate and sign the exact collection-scoped HS256 JWT documented in configuration.md.
PDF_BRIDGE_QDRANT_API_KEY=CHANGE_ME_qdrant_scoped_HS256_JWT
PDF_BRIDGE_FORMATTER_API_TOKEN=CHANGE_ME_formatter_only_token
PDF_BRIDGE_LLM_API_TOKEN=CHANGE_ME_advisory_only_token

PDF_BRIDGE_APP_ENV=development
PDF_BRIDGE_AUTH_MODE=anonymous-poc
PDF_BRIDGE_BIND_ADDRESS=127.0.0.1
PDF_BRIDGE_PORT=8000
PDF_BRIDGE_ALLOWED_HOSTS=["localhost","127.0.0.1","app"]
PDF_BRIDGE_TRUSTED_PROXY_CIDRS=[]
PDF_BRIDGE_TRUSTED_IDENTITY_HEADER=X-Forwarded-User

# Direct processes must use an absolute, non-synchronized storage directory.
# Compose supplies /var/lib/pdf-bridge and the SQLite URL automatically.
# PDF_BRIDGE_STORAGE_ROOT=/var/lib/pdf-bridge
# PDF_BRIDGE_DATABASE_URL=sqlite+pysqlite:////var/lib/pdf-bridge/catalog.sqlite3
PDF_BRIDGE_COLLECTIONS=[{"key":"customer","display_name":"Customer Product","description":"Approved product and support material available to customer-facing assistants.","audience":"customer","qdrant_collection_name":"customer-product-pdfs","enabled":true},{"key":"internal","display_name":"HR & Internal","description":"Employee-only policy and operations material.","audience":"internal","qdrant_collection_name":"internal-pdfs","enabled":true}]

PDF_BRIDGE_MAX_UPLOAD_BYTES=52428800
# Streamlit-only launcher settings; the Litestar Settings loader explicitly ignores these keys.
PDF_BRIDGE_URL=http://127.0.0.1:8000
PDF_BRIDGE_STREAMLIT_MAX_UPLOAD_FILES=5
PDF_BRIDGE_STREAMLIT_BIND_ADDRESS=127.0.0.1
PDF_BRIDGE_STREAMLIT_PORT=8501
# Set this to the proxy-injected header name only in a trusted-header deployment.
PDF_BRIDGE_STREAMLIT_IDENTITY_HEADER=
PDF_BRIDGE_UPLOAD_CHUNK_BYTES=1048576
PDF_BRIDGE_CLAMD_TIMEOUT_SECONDS=30
PDF_BRIDGE_CLAMD_STREAM_MAX_BYTES=67108864
PDF_BRIDGE_PARSE_WALL_CLOCK_SECONDS=120
PDF_BRIDGE_PARSE_CPU_SECONDS=90
PDF_BRIDGE_PARSE_MEMORY_BYTES=1073741824
PDF_BRIDGE_MAX_PAGES=2000
PDF_BRIDGE_MAX_EXTRACTED_CHARACTERS=5000000
PDF_BRIDGE_MAX_CHUNKS=10000

# Separate private vLLM formatter boundary.
# vLLM server root: Bridge appends /tokenize, /tokenizer_info, /v1/models, and
# /v1/chat/completions itself.
PDF_BRIDGE_FORMATTER_API_URL=https://formatter.internal.example
PDF_BRIDGE_FORMATTER_MODEL_ID=CHANGE_ME_formatter_model_id
PDF_BRIDGE_FORMATTER_MODEL_REVISION=CHANGE_ME_immutable_formatter_revision
PDF_BRIDGE_FORMATTER_TOKENIZER_CLASS=CHANGE_ME_exact_served_tokenizer_class
PDF_BRIDGE_FORMATTER_PROMPT_REVISION=formatter-prompt-v1
PDF_BRIDGE_FORMATTER_SCHEMA_REVISION=formatter-schema-v1
PDF_BRIDGE_FORMATTER_TIMEOUT_SECONDS=120
PDF_BRIDGE_FORMATTER_MAX_INPUT_TOKENS=24000
PDF_BRIDGE_FORMATTER_MAX_OUTPUT_TOKENS=12000
PDF_BRIDGE_FORMATTER_TOKEN_SAFETY_RESERVE=512
PDF_BRIDGE_FORMATTER_MAX_PAGES_PER_REQUEST=8
PDF_BRIDGE_FORMATTER_MAX_ATTEMPTS=2

# Separate private advisory classifier/verifier boundary.
PDF_BRIDGE_LLM_API_URL=https://advisory.internal.example/v1
PDF_BRIDGE_LLM_CLASSIFIER_MODEL=CHANGE_ME_classifier_model_id
PDF_BRIDGE_LLM_CLASSIFIER_MODEL_REVISION=CHANGE_ME_immutable_classifier_revision
PDF_BRIDGE_LLM_CLASSIFIER_PROMPT_REVISION=classifier-prompt-v1
PDF_BRIDGE_LLM_VERIFIER_MODEL=CHANGE_ME_verifier_model_id
PDF_BRIDGE_LLM_VERIFIER_MODEL_REVISION=CHANGE_ME_immutable_verifier_revision
PDF_BRIDGE_LLM_VERIFIER_PROMPT_REVISION=verifier-prompt-v1
PDF_BRIDGE_LLM_TIMEOUT_SECONDS=60
PDF_BRIDGE_LLM_MAX_INPUT_TOKENS=12000
PDF_BRIDGE_LLM_MAX_OUTPUT_TOKENS=2048
PDF_BRIDGE_LLM_MAX_ATTEMPTS=2

# Review and pre-seed this cache before startup; network fallback is disabled.
PDF_BRIDGE_MODEL_CACHE_HOST_PATH=CHANGE_ME_absolute_host_model_cache
PDF_BRIDGE_MODEL_CACHE_DIR=/var/cache/pdf-bridge-models
PDF_BRIDGE_MODEL_LOCAL_FILES_ONLY=true
PDF_BRIDGE_DENSE_MODEL_REVISION=CHANGE_ME_40_to_64_character_commit_hash
PDF_BRIDGE_DENSE_DEVICE=cpu
PDF_BRIDGE_DENSE_BATCH_SIZE=16
PDF_BRIDGE_SPARSE_MODEL_REVISION=CHANGE_ME_exact_64_character_manifest_SHA256

PDF_BRIDGE_QDRANT_URL=http://qdrant:6333
PDF_BRIDGE_QDRANT_SCREENING_COLLECTION_NAME=pdf-bridge-screening
PDF_BRIDGE_QDRANT_TIMEOUT_SECONDS=30

PDF_BRIDGE_WORKER_ENABLED=true
PDF_BRIDGE_WORKER_POLL_SECONDS=1
PDF_BRIDGE_WORKER_LEASE_SECONDS=300
PDF_BRIDGE_WORKER_HEARTBEAT_SECONDS=30
PDF_BRIDGE_WORKER_MAX_OPERATION_SECONDS=3600

# Leave both blank when operator diagnostics are intentionally disabled.
PDF_BRIDGE_SEARCH_API_URL=
PDF_BRIDGE_SEARCH_API_TOKEN=
PDF_BRIDGE_SEARCH_API_TIMEOUT_SECONDS=10
